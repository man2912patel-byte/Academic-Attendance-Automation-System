# ==============================================================================
# BACKEND CONFIGURATION (.env)
# ==============================================================================
FLASK_APP=run.py
FLASK_ENV=development
FLASK_DEBUG=True
SECRET_KEY=your_super_secret_jwt_and_session_signing_key_here

# SQLite connection string (Local Development)
DATABASE_URL=sqlite:///database/development.db

# PostgreSQL connection string (Production - e.g., Render database url)
# DATABASE_URL=postgresql://user:password@hostname:5432/dbname

# CORS configuration
ALLOWED_ORIGINS=http://localhost:5173,https://your-vercel-domain.vercel.app

# Google Sheets Config fallback client
GOOGLE_CREDENTIALS_JSON_PATH=credentials.json


# ==============================================================================
# FRONTEND CONFIGURATION (frontend/.env)
# ==============================================================================
VITE_API_BASE_URL=http://localhost:5000/api
